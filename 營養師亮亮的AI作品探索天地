<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>亮亮 · 營養師與AI探索者 | 首頁介紹</title>
    <style>
        /* ---------- RESET & 全域變數 (低飽和中性色調) ---------- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-main: #F5F3EF;        /* 暖灰米白基底 */
            --card-bg: #FFFFFF;
            --text-primary: #2C2A29;
            --text-secondary: #5F5B57;
            --text-soft: #7E7A75;
            --accent-light: #D9D2C5;   /* 中性柔和邊框／點綴 */
            --accent-soft: #B7AD9F;
            --tag-bg: #EFEBE5;
            --shadow-sm: 0 8px 20px rgba(0, 0, 0, 0.02), 0 2px 6px rgba(0, 0, 0, 0.03);
            --shadow-md: 0 12px 28px rgba(0, 0, 0, 0.04), 0 0 0 1px rgba(0, 0, 0, 0.01);
            --radius-card: 28px;
            --radius-tag: 40px;
            --transition: all 0.2s ease;
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-primary);
            font-family: system-ui, -apple-system, 'Segoe UI', 'Roboto', 'Noto Sans', 'Helvetica Neue', sans-serif;
            line-height: 1.5;
            scroll-behavior: smooth;
            /* 動態字體基礎尺寸：讓螢幕舒適 (clamp 確保小螢幕不小、大螢幕優雅) */
            font-size: clamp(1rem, 1.8vw, 1.125rem);
        }

        /* 整體容器 - 置中且有呼吸感 */
        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        /* 所有區塊間距 */
        section {
            margin-bottom: 4rem;
        }

        /* 標題風格 */
        .section-title {
            font-size: clamp(1.6rem, 4vw, 2.2rem);
            font-weight: 600;
            letter-spacing: -0.01em;
            margin-bottom: 2rem;
            color: var(--text-primary);
            border-left: 4px solid var(--accent-soft);
            padding-left: 1.2rem;
        }

        /* Hero 區塊 */
        .hero {
            text-align: center;
            padding: 3rem 0 2rem;
            margin-bottom: 2rem;
        }
        .hero-name {
            font-size: clamp(2.2rem, 7vw, 3.8rem);
            font-weight: 700;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #3C3A37 0%, #6C655C 100%);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0.75rem;
        }
        .hero-tagline {
            font-size: clamp(1rem, 2.8vw, 1.35rem);
            color: var(--text-secondary);
            max-width: 720px;
            margin: 0 auto;
            font-weight: 400;
            border-top: 1px solid var(--accent-light);
            display: inline-block;
            padding-top: 1rem;
        }
        .hero-divider {
            width: 70px;
            height: 2px;
            background: var(--accent-soft);
            margin: 1.5rem auto 0;
            opacity: 0.5;
        }

        /* 卡片通用設計 */
        .card {
            background: var(--card-bg);
            border-radius: var(--radius-card);
            box-shadow: var(--shadow-md);
            padding: 2rem;
            transition: var(--transition);
        }
        .card:hover {
            box-shadow: 0 20px 32px rgba(0, 0, 0, 0.05), 0 0 0 1px rgba(0, 0, 0, 0.01);
        }

        /* 關於我區域：標籤容器 */
        .about-content {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        .intro-text {
            font-size: 1rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }
        .tag-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin-top: 0.5rem;
        }
        .tag {
            background: var(--tag-bg);
            color: var(--text-primary);
            padding: 0.4rem 1rem;
            border-radius: var(--radius-tag);
            font-size: 0.85rem;
            font-weight: 470;
            letter-spacing: 0.3px;
            transition: var(--transition);
            backdrop-filter: blur(2px);
        }
        .tag:hover {
            background: #E3DDD4;
            transform: translateY(-1px);
        }

        /* 專業與興趣區塊 - 兩欄響應式 */
        .skills-interests-grid {
            display: grid;
            grid-template-columns: 1fr 1.1fr;
            gap: 2rem;
        }
        @media (max-width: 780px) {
            .skills-interests-grid {
                grid-template-columns: 1fr;
                gap: 1.8rem;
            }
            .container {
                padding: 1.5rem 1.2rem 3rem;
            }
            .card {
                padding: 1.5rem;
            }
        }

        /* 硬技能項目 */
        .skill-items {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        .skill-item {
            border-bottom: 1px solid var(--accent-light);
            padding-bottom: 1rem;
        }
        .skill-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }
        .skill-name {
            font-weight: 650;
            font-size: 1.1rem;
            color: var(--text-primary);
            margin-bottom: 0.4rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .skill-desc {
            font-size: 0.9rem;
            color: var(--text-secondary);
            line-height: 1.45;
        }
        /* 興趣項目 (三塊) */
        .hobby-list {
            display: flex;
            flex-direction: column;
            gap: 1.8rem;
        }
        .hobby-item {
            background: #FCFAF7;
            border-radius: 24px;
            padding: 0.2rem 0 0.2rem 0;
        }
        .hobby-title {
            font-weight: 620;
            font-size: 1.08rem;
            margin-bottom: 0.5rem;
            color: #4D453C;
            display: inline-block;
            background: #EFEBE5;
            padding: 0.2rem 1rem;
            border-radius: 40px;
            letter-spacing: 0.3px;
        }
        .hobby-desc {
            color: var(--text-secondary);
            font-size: 0.92rem;
            line-height: 1.55;
            margin-top: 0.7rem;
            padding-left: 0.2rem;
        }

        /* 聯絡區塊 (移除色彩模塊後，單一卡片優化) */
        .contact-section {
            display: flex;
            gap: 2rem;
        }
        .contact-info {
            flex: 1;
            width: 100%;
        }
        .contact-links {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin: 1rem 0 0.8rem;
        }
        .contact-link {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            background: var(--tag-bg);
            padding: 0.7rem 1.4rem;
            border-radius: 60px;
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-primary);
            text-decoration: none;
            transition: var(--transition);
            border: 1px solid transparent;
        }
        .contact-link:hover {
            background: #E2DAD1;
            border-color: var(--accent-soft);
            transform: scale(0.98);
        }
        hr {
            margin: 1.5rem 0 0.5rem;
            border: none;
            height: 1px;
            background: var(--accent-light);
            opacity: 0.5;
        }
        .footer-note {
            text-align: center;
            font-size: 0.75rem;
            color: var(--text-soft);
            margin-top: 3rem;
            padding-top: 1rem;
            border-top: 1px solid var(--accent-light);
        }

        /* 小調整讓按鈕與整體更協調 */
        @media (max-width: 550px) {
            .contact-section {
                flex-direction: column;
                align-items: stretch;
            }
            .contact-links {
                flex-direction: column;
                align-items: stretch;
            }
            .contact-link {
                justify-content: center;
            }
            .hero {
                padding: 1.5rem 0 1rem;
            }
        }
        /* 自適應字體加強 (body 基礎字體已經 clamp, 內部元素相對 rem 即可) */
        h1, h2, h3, .hero-name, .section-title {
            line-height: 1.2;
        }
        a, button {
            cursor: pointer;
        }
        .highlight-icon {
            font-size: 1.1em;
            opacity: 0.75;
        }
    </style>
</head>
